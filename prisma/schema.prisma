generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model countries {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

/*
* ==========================================
*
*          主要なPrismaコマンド
*
* ==========================================
*
* npx prisma generate
* -------------------
* schema.prisma の内容に基づいて、Prisma Client (このプロジェクトでは app/generated/prisma)
* を生成・更新します。スキーマファイルを変更した後は、必ずこのコマンドを実行してください。
*
* npx prisma db pull
* ------------------
* 既存のデータベースのスキーマを読み取り、この schema.prisma ファイルに反映させます。
* データベース側で直接テーブルやカラムを変更した後に使用します。
*
* npx prisma migrate dev
* --------------------
* 開発環境でマイグレーションを実行します。schema.prisma の変更を元にSQLマイグレーション
* ファイルを作成し、データベースに適用します。データベースの状態を変更する主要な方法です。
* --name "migration-name" でマイグレーションに名前を付けることができます。
*
* npx prisma studio
* -----------------
* ブラウザベースのGUIを起動し、データベースのデータを直接表示・編集できます。
* 開発中のデータ確認や簡単なデータ操作に非常に便利です。
*
*/